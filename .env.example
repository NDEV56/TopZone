# TopZone — contoh .env (copy ke .env lalu edit)
# Tidak akan ikut ke git (.gitignore sudah meng-exclude .env asli).

NGROK_AUTHTOKEN=isi_token_dari_dashboard.ngrok.com
NGROK_DOMAIN=
CLOUDFLARED_TOKEN=
SERVER_MODE=auto
LOCAL_PORT=0
PHP_PORT=8080
PHP_ROOT=C:\xampp\htdocs\TopZone\Home
TUNNEL_PROVIDER=ngrok
TUNNEL_FALLBACK=true
LOG_REQUESTS=true
GUI_PORT=4747
GUI_BIND=127.0.0.1
GUI_PASSWORD=isi_password_kuat_disini_atau_kosong
GUI_AUTO_OPEN=true
SEC_RATE_LIMIT=60
SEC_BLOCK_ON_FAIL=5
SEC_BLOCK_DURATION=300
AUTO_UPDATE=ask
UPDATE_BRANCH=main
UPDATE_REMOTE=origin
LOG_MIN_LEVEL=common
LOG_RETENTION_DAYS=30
