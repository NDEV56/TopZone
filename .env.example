# ═══════════════════════════════════════════════════════════════════
#  TOPZONE — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════
#  1. Copy file ini jadi .env  →  cp .env.example .env
#  2. Isi nilai-nilai di bawah sesuai kebutuhan
#  3. Jangan pernah commit file .env ke git!
# ═══════════════════════════════════════════════════════════════════


# ─── 🌐 NGROK TUNNEL (wajib) ─────────────────────────────────────
# Dapatkan token gratis di:
#   https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=isi_token_ngrok_disini

# Custom domain (opsional, butuh paid plan)
# Contoh: NGROK_DOMAIN=topzone.ngrok.app
# NGROK_DOMAIN=


# ─── 🚀 SERVER MODE ──────────────────────────────────────────────
# Pilihan: auto | xampp | laragon | wamp | mamp | php | custom
#   auto    = deteksi otomatis (paling aman)
#   xampp   = XAMPP Apache (port 80/8080)
#   laragon = Laragon (port 80/8080)
#   wamp    = WampServer (port 80/8080)
#   mamp    = MAMP (port 8888)
#   php     = PHP built-in server (butuh PHP di PATH)
#   custom  = manual, isi LOCAL_PORT
SERVER_MODE=auto

# Port custom (cuma dipakai kalau SERVER_MODE=custom)
# LOCAL_PORT=80

# Port PHP built-in (cuma dipakai kalau SERVER_MODE=php)
# PHP_PORT=8080

# Folder root PHP built-in (cuma dipakai kalau SERVER_MODE=php)
# PHP_ROOT=./Home


# ─── 📡 LOGGING ──────────────────────────────────────────────────
# true = tampilkan request log realtime di terminal
LOG_REQUESTS=true


# ─── 💳 XENDIT PAYMENT GATEWAY ───────────────────────────────────
# Daftar di: https://dashboard.xendit.co
# Settings → API Keys → Generate Secret Key
#   - Test mode  : xnd_development_xxxxx
#   - Production : xnd_production_xxxxx
XENDIT_SECRET_KEY=xnd_development_isi_key_disini

# URL publik untuk redirect setelah pembayaran berhasil/gagal
# Saat dev pakai URL ngrok, contoh: https://xxx.ngrok-free.app
BASE_URL=http://localhost


# ─── 🗄️ DATABASE ────────────────────────────────────────────────
# Default sesuai XAMPP/Laragon (root tanpa password)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=topzone
DB_PORT=3306


# ─── 🔒 KEAMANAN ─────────────────────────────────────────────────
# Secret key untuk CSRF token & session — generate random:
#   php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=ganti_dengan_random_string_panjang

# Mode aplikasi: development | production
APP_ENV=development

# Aktifkan debug mode (tampilkan error PHP, JANGAN nyala di production)
APP_DEBUG=true


# ─── 📧 EMAIL (opsional, untuk notifikasi) ───────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@topzone.com
