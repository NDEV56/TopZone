# ────────────────────────────────────────────────────
#  TopZone Universal Launcher — contoh .env
# ────────────────────────────────────────────────────
#  Salin file ini → .env lalu edit nilainya.
#  File .env ASLI tidak ikut di git (sudah di .gitignore).
#  Kosongkan baris kalau ingin pakai default.
# ────────────────────────────────────────────────────

# === NGROK / TUNNEL ===
NGROK_AUTHTOKEN=isi_token_dari_dashboard.ngrok.com
NGROK_DOMAIN=
TUNNEL_PROVIDER=ngrok
TUNNEL_FALLBACK=true
CLOUDFLARED_TOKEN=

# === SERVER LOKAL ===
# Mode: auto | xampp | laragon | wamp | mamp | ampps | openserver
#       usbwebserver | easyphp | php | custom
SERVER_MODE=auto
LOCAL_PORT=0
PHP_PORT=8080
PHP_ROOT=./Home

# === GUI CONTROL PANEL ===
GUI_PORT=4747
GUI_BIND=127.0.0.1
GUI_PASSWORD=
GUI_AUTO_OPEN=true

# === KEAMANAN ===
SEC_RATE_LIMIT=60
SEC_BLOCK_ON_FAIL=5
SEC_BLOCK_DURATION=300

# === LOG ===
LOG_REQUESTS=true
LOG_MIN_LEVEL=common
LOG_RETENTION_DAYS=30

# === AUTO UPDATE ===
# ask  = tanya dulu (default, paling aman)
# true = pull otomatis
# false= jangan pernah cek
AUTO_UPDATE=ask
UPDATE_BRANCH=main
UPDATE_REMOTE=origin
