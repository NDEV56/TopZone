# ════════════════════════════════════════════════════════════
#  Home/.htaccess — Apache hardening untuk webroot TopZone
# ════════════════════════════════════════════════════════════

# ─── Tutup file sensitif ───────────────────────────────────
<FilesMatch "(?i)^(\.env|\.htaccess|\.htpasswd|\.git|\.gitignore|composer\.(json|lock)|package(-lock)?\.json|_security\.php|migrasi_produk\.php)$">
  Require all denied
</FilesMatch>

<FilesMatch "(?i)\.(?:bak|swp|old|orig|backup|sql|log|sqlite|db|env)$">
  Require all denied
</FilesMatch>

# ─── Disable directory listing ─────────────────────────────
Options -Indexes -ExecCGI

# ─── Rewrite untuk cegah upload PHP execution di subfolder gambar ───
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Tolak request langsung ke file PHP di /uploads/
  RewriteRule ^uploads/.+\.(?:php\d?|phtml|phar|html?|js|sh|cgi|pl|asp|aspx|jsp|exe|bat|cmd)$ - [F,L,NC]
</IfModule>

# ─── Security headers ─────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "interest-cohort=(), camera=(), microphone=()"
  # Hapus header yang bocor versi
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ─── Server signature off ─────────────────────────────────
ServerSignature Off

# ─── Default 403 / 404 page yang ramah ────────────────────
ErrorDocument 403 "Akses ditolak."
ErrorDocument 404 "Halaman tidak ditemukan."
