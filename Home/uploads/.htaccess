# ════════════════════════════════════════════════════════════════════
#  Block PHP execution di folder uploads (mencegah upload shell)
# ════════════════════════════════════════════════════════════════════

# Blok semua file selain gambar
<FilesMatch "\.(php|phtml|phar|pht|cgi|sh|py|pl)$">
    Require all denied
</FilesMatch>

# Pastikan PHP engine OFF (kalau Apache + mod_php)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>

# Cegah listing direktori
Options -Indexes -ExecCGI
AddHandler cgi-script .php .phtml .phar
RemoveHandler .php .phtml .phar
